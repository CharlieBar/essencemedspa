  "effects": {
    "radius": {
      "circle": { "value": "50%", "usage": "Service icon, custom cursor, social icons, progress dots" },
      "scroll-cue-pill": { "value": "20px", "usage": "Scroll indicator border-radius" },
      "buttons": { "value": "0", "usage": "All buttons are square — no border-radius" }
    },
    "transitions": {
      "fast": { "value": "0.3s ease", "usage": "Footer link/social color changes" },
      "normal": { "value": "0.4s ease", "usage": "Nav collapse, cursor size, service icon borders" },
      "medium-bezier": { "value": "0.4s cubic-bezier(0.65, 0, 0.35, 1)", "usage": "Nav underline scale, cursor easing" },
      "slow-bezier": { "value": "0.5s cubic-bezier(0.65, 0, 0.35, 1)", "usage": "Button fill wipe (translateX/translateY)" },
      "service-full": { "value": "0.6s cubic-bezier(0.65, 0, 0.35, 1)", "usage": "Service card hover overlay + card-level transition" },
      "image-slow": { "value": "1.5s cubic-bezier(0.65, 0, 0.35, 1)", "usage": "About image scroll reveal" }
    },
    "animations": {
      "grain": {
        "name": "grainMove",
        "duration": "8s",
        "timing": "steps(10)",
        "iteration": "infinite",
        "note": "SVG fractalNoise rendered as inline data URI, positioned fixed full-screen at 200% size, opacity 0.04"
      },
      "loaderBgWipe": {
        "name": "loaderBg",
        "duration": "1s",
        "easing": "cubic-bezier(0.76, 0, 0.24, 1)",
        "delay": "0.3s",
        "pattern": "scaleY 0→1 from bottom then 1→0 from top (origin flip at 50.1%)"
      },
      "loaderCharReveal": {
        "name": "charReveal",
        "duration": "0.8s",
        "easing": "cubic-bezier(0.65, 0, 0.35, 1)",
        "pattern": "translateY(100%) → translateY(0), per character, delays 0.1s–0.4s"
      },
      "heroImageReveal": {
        "name": "heroImageReveal",
        "duration": "2s",
        "easing": "cubic-bezier(0.65, 0, 0.35, 1)",
        "delay": "1.8s",
        "pattern": "scale(1.2)+opacity(0) → scale(1)+opacity(1)"
      },
      "heroTitleWordReveal": {
        "name": "wordReveal",
        "duration": "1.2s",
        "easing": "cubic-bezier(0.65, 0, 0.35, 1)",
        "pattern": "translateY(100%)+opacity(0) → translateY(0)+opacity(1)",
        "delays": ["2.1s line1", "2.3s line2", "2.5s line3"],
        "container": "Each word wrapped in overflow:hidden span"
      },
      "heroContentSlideUp": {
        "name": "slideUp",
        "duration": "1s",
        "easing": "ease",
        "pattern": "translateY(30px)+opacity(0) → translateY(0)+opacity(1)",
        "elements": [
          "hero-tag: delay 2s",
          "hero-desc: delay 2.7s",
          "hero-cta: delay 2.9s",
          "scroll-cue: delay 3.2s (uses fadeIn)"
        ]
      },
      "scrollReveal": {
        "trigger": "IntersectionObserver — element top < (viewportHeight - 100px)",
        "initial": "opacity:0; transform:translateY(60px)",
        "final": "opacity:1; transform:translateY(0)",
        "duration": "1s",
        "easing": "cubic-bezier(0.65, 0, 0.35, 1)",
        "staggerClasses": ["reveal", "reveal-delay-1 (+0.1s)", "reveal-delay-2 (+0.2s)", "reveal-delay-3 (+0.3s)"]
      },
      "aboutImageReveal": {
        "trigger": "IntersectionObserver, class 'revealed' added",
        "image": "opacity:0;scale(1.3) → opacity:1;scale(1) over 1.5s",
        "overlay": "scaleX(1) transform-origin:right → scaleX(0) over 1.2s (red wipe uncovers image)"
      },
      "marquee": {
        "name": "marqueeScroll",
        "duration": "25s",
        "easing": "linear",
        "iteration": "infinite",
        "pattern": "translateX(0) → translateX(-50%), two identical content blocks"
      },
      "scrollBounce": {
        "duration": "2s",
        "easing": "ease-in-out",
        "iteration": "infinite",
        "pattern": "dot top:10px opacity:1 → top:30px opacity:0.3"
      }
    },
    "customCursor": {
      "defaultSize": "20px",
      "defaultBorder": "1px solid #FF3D00",
      "dotSize": "5px",
      "dotBackground": "#FF3D00",
      "hoverSize": "60px",
      "hoverBorderColor": "#C4A052",
      "hoverBackground": "rgba(196,160,82,0.1)",
      "transitionExpand": "0.3s ease width/height, 0.3s ease border-color",
      "hiddenBelow": "768px"
    },
    "grainOverlay": {
      "opacity": "0.04",
      "zIndex": "9997",
      "size": "200% × 200% of viewport, positioned at -50% -50%",
      "pointerEvents": "none"
    }
  },
